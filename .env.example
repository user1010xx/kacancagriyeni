# ⚠️ BU DOSYA ÖRNEKTİR. GERÇEK DEĞERLERİ ASLA BURAYA YAZMA!
# Gerçek .env dosyası .gitignore ile korunur.
# Bu dosyayı kopyalayıp .env olarak kullan.

TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=

# PBX sağlayıcı: toniva (varsayılan) | invekto
PBX_PROVIDER=toniva

# --- Toniva ---
TONIVA_API_KEY=
# TONIVA_BASE_URL=https://crm.toniva.net/api/public/v1
# İzlenecek kuyruk(lar), virgülle: UI'daki "1000 (1000)" → 1000
TONIVA_QUEUE=1000
# Kaçan çağrı status etiketi (varsayılan: Cevapsız)
# TONIVA_MISSED_STATUS=Cevapsız

# --- Invekto (PBX_PROVIDER=invekto iken) ---
# INVEKTO_DEPARTMENT_NAME=Gelen Arama,MESAI DIŞI
# INVEKTO_DEPARTMENT_LOOSE_MATCH=false
# Firma kodu bot içinden /firmakodu ile de ayarlanır.

POLLING_INTERVAL_SECONDS=30
# Toniva'da IsCompleted genelde yok; true kalsa bile cevapsız filtresi yeterlidir.
NOTIFY_UNCOMPLETED_ONLY=true
BOT_TIMEZONE=Europe/Istanbul
DAILY_REPORT_HOUR=10
# /iletilenkacancagri kayitlarini saklama suresi (gun)
DELIVERED_RETENTION_DAYS=30

# Deploy sonrası tek seferlik backfill (yalnızca BACKFILL_DATES doluysa çalışır)
BACKFILL_ON_STARTUP=true
# BACKFILL_DATES=18.07.2026
# BACKFILL_AFTER_TIME=14:57:00
# BACKFILL_THROTTLE_SECONDS=0.15

# İlk kurulum flood koruması: dedup deposu boşsa bugünkü çağrıları bildirimsiz işaretle
SEED_TODAY_ON_STARTUP=true
# SEED_TODAY_FORCE=true   # depo dolu olsa bile bugünü yeniden seed et (bildirim yok)

# Railway volume desteği için (UI'dan Volume ekledikten sonra):
# DATA_DIR=/app/data
